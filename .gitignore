# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# CMake build directories (CMakePresets.json binaryDir targets) -- not
# root-anchored: packaging_check/'s own documented usage builds into
# packaging_check/build/, a nested path a root-anchored /build/ wouldn't
# catch (found firing 31 while adding that directory).
build/
CMakeUserPresets.json

# Editor-local state -- this project ships a real .clangd config (root
# CMakeLists.txt's CMAKE_EXPORT_COMPILE_COMMANDS), so editor tooling is a
# deliberate concern here, not incidental; a contributor's own VS Code/CLion
# workspace state shouldn't end up tracked alongside it.
.vscode/
.idea/
